#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════
# Sage CLI
#
# Usage:
#   sage new <name>     Create a new project with Sage
#   sage init           Add Sage to the current directory
#   sage update         Regenerate platform files
#   sage upgrade        Update Sage to the latest version
#   sage help           Show available commands
# ═══════════════════════════════════════════════════════════════
set -euo pipefail

# ── Colors ──
BOLD='\033[1m'
GREEN='\033[32m'
YELLOW='\033[33m'
CYAN='\033[36m'
RED='\033[31m'
DIM='\033[2m'
RESET='\033[0m'

# ── Rich output helpers ──
SAGE_START_TIME=""
STEP_START_TIME=""

# macOS date doesn't support %N — outputs literal "N" instead of failing
_sage_now() {
  local t
  t=$(date +%s%N 2>/dev/null || date +%s)
  # Strip non-digits (macOS outputs "1774343489N")
  t="${t//[!0-9]/}"
  # If length <= 10, it's seconds only — no nanosecond support
  if [ ${#t} -le 10 ]; then
    echo "${t}000000000"
  else
    echo "$t"
  fi
}

timer_start() { SAGE_START_TIME=$(_sage_now); }
step_start()  { STEP_START_TIME=$(_sage_now); }

elapsed_ms() {
  local now start
  now=$(_sage_now)
  start="${1:-$STEP_START_TIME}"
  echo $(( (now - start) / 1000000 ))
}

fmt_time() {
  local ms="$1"
  if [ "$ms" -lt 1000 ]; then
    echo "${ms}ms"
  else
    local s=$((ms / 1000))
    local rem=$((ms % 1000 / 100))
    echo "${s}.${rem}s"
  fi
}

section() {
  echo ""
  echo -e "  ${BOLD}┌─ $1${RESET}"
}

section_end() {
  echo -e "  ${BOLD}│${RESET}"
}

step_ok() {
  local ms
  ms=$(elapsed_ms "$STEP_START_TIME")
  local time_str
  time_str=$(fmt_time "$ms")
  printf "  │  ${GREEN}✓${RESET} %-42s ${DIM}%s${RESET}\n" "$1" "$time_str"
  step_start
}

step_ok_notimed() {
  echo -e "  │  ${GREEN}✓${RESET} $1"
}

step_warn() {
  echo -e "  │  ${YELLOW}⚠${RESET} $1"
}

step_fail() {
  echo -e "  │  ${RED}✗${RESET} $1"
}

step_info() {
  echo -e "  │  ${CYAN}↻${RESET} $1"
}

sage_complete() {
  local total_ms
  total_ms=$(elapsed_ms "$SAGE_START_TIME")
  local time_str
  time_str=$(fmt_time "$total_ms")
  echo -e "  ${BOLD}└─ Complete${RESET}  ${DIM}${time_str} total${RESET}"
  echo ""
}

spin() {
  local pid=$1 msg="${2:-Working...}"
  # Non-interactive: just wait silently
  if [ ! -t 1 ]; then
    wait "$pid" 2>/dev/null
    return $?
  fi
  local chars='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
  while kill -0 "$pid" 2>/dev/null; do
    for i in $(seq 0 $((${#chars} - 1))); do
      kill -0 "$pid" 2>/dev/null || break
      printf "\r  ${DIM}${chars:$i:1} %s${RESET}" "$msg"
      sleep 0.08
    done
  done
  printf "\r                                                       \r"
  wait "$pid" 2>/dev/null
  return $?
}

# ── Resolve framework source ──
# Priority: 1) SAGE_HOME env  2) ~/.sage/framework  3) script's own directory
resolve_framework() {
  # Global install
  if [ -n "${SAGE_HOME:-}" ] && [ -d "$SAGE_HOME/framework/core" ]; then
    SAGE_FRAMEWORK="$SAGE_HOME/framework"
    return
  fi

  if [ -d "$HOME/.sage/framework/core" ]; then
    SAGE_FRAMEWORK="$HOME/.sage/framework"
    return
  fi

  # Local — script lives in bin/ inside the framework
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local parent_dir="$(dirname "$script_dir")"

  if [ -d "$parent_dir/core" ] && [ -d "$parent_dir/skills" ]; then
    SAGE_FRAMEWORK="$parent_dir"
    return
  fi

  echo -e "${RED}❌ Cannot find Sage framework.${RESET}"
  echo ""
  echo "  Install Sage first:"
  echo "    curl -fsSL https://raw.githubusercontent.com/xoai/sage/main/install.sh | bash"
  exit 1
}

resolve_framework

# ═══════════════════════════════════════════════════════════════
# SHARED FUNCTIONS
# ═══════════════════════════════════════════════════════════════

ask_choice() {
  local prompt="$1"
  shift
  local options=("$@")
  local count=${#options[@]}

  echo "" >&2
  echo -e "  ${BOLD}$prompt${RESET}" >&2
  echo "" >&2
  for i in "${!options[@]}"; do
    echo "    $((i + 1))) ${options[$i]}" >&2
  done
  echo "" >&2
  printf "  Choice [1-$count]: " >&2
  read -r choice

  if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt "$count" ]; then
    choice=1
  fi
  echo "$choice"
}

select_platform() {
  local target="$1"
  PLATFORM=""

  # Auto-detect from existing files
  local has_agent=false has_claude=false
  [ -d "$target/.agent" ] && has_agent=true
  [ -f "$target/GEMINI.md" ] && has_agent=true
  [ -d "$target/.claude" ] && has_claude=true
  # Check if CLAUDE.md is Sage-generated
  if [ -f "$target/CLAUDE.md" ] && head -1 "$target/CLAUDE.md" | grep -q "Sage"; then
    has_claude=true
  fi

  if [ "$has_agent" = true ] && [ "$has_claude" = true ]; then
    PLATFORM="both"
    echo -e "  ${GREEN}Detected:${RESET} Both platforms"
    return
  elif [ "$has_agent" = true ]; then
    PLATFORM="antigravity"
    echo -e "  ${GREEN}Detected:${RESET} Antigravity"
    return
  elif [ "$has_claude" = true ]; then
    PLATFORM="claude-code"
    echo -e "  ${GREEN}Detected:${RESET} Claude Code"
    return
  fi

  # Ask interactively
  if [ -t 0 ]; then
    local choice
    choice=$(ask_choice "Which platform are you using?" "Claude Code" "Antigravity" "Both")
    case "$choice" in
      2) PLATFORM="antigravity" ;;
      3) PLATFORM="both" ;;
      *) PLATFORM="claude-code" ;;
    esac
  else
    PLATFORM="claude-code"
  fi
}

detect_stack() {
  local target="$1"
  DETECTED_STACK=""

  if [ -f "$target/package.json" ]; then
    local pkg="$target/package.json"
    grep -q '"next"' "$pkg" 2>/dev/null && DETECTED_STACK="$DETECTED_STACK next"
    grep -q '"react"' "$pkg" 2>/dev/null && DETECTED_STACK="$DETECTED_STACK react"
    grep -q '"vue"' "$pkg" 2>/dev/null && DETECTED_STACK="$DETECTED_STACK vue"
    grep -q '"svelte"' "$pkg" 2>/dev/null && DETECTED_STACK="$DETECTED_STACK svelte"
    grep -q '"react-native"' "$pkg" 2>/dev/null && DETECTED_STACK="$DETECTED_STACK react-native"
    grep -q '"@supabase"' "$pkg" 2>/dev/null && DETECTED_STACK="$DETECTED_STACK supabase"
    grep -q '"firebase"' "$pkg" 2>/dev/null && DETECTED_STACK="$DETECTED_STACK firebase"
    grep -q '"express"\|"fastify"\|"hono"' "$pkg" 2>/dev/null && DETECTED_STACK="$DETECTED_STACK node-api"
  fi
  [ -f "$target/pubspec.yaml" ] && DETECTED_STACK="$DETECTED_STACK flutter"
  [ -f "$target/requirements.txt" ] || [ -f "$target/pyproject.toml" ] && DETECTED_STACK="$DETECTED_STACK python"
  [ -f "$target/go.mod" ] && DETECTED_STACK="$DETECTED_STACK go"
  [ -f "$target/Cargo.toml" ] && DETECTED_STACK="$DETECTED_STACK rust"

  DETECTED_STACK=$(echo "$DETECTED_STACK" | xargs)

  if [ -z "$DETECTED_STACK" ]; then
    echo -e "  ${DIM}No stack detected${RESET}"
  else
    echo -e "  ${GREEN}Stack:${RESET} $DETECTED_STACK"
  fi
}

copy_framework() {
  local target="$1"
  if [ -d "$target/sage" ]; then
    echo -e "  ${GREEN}✓${RESET} sage/ already present"
  else
    cp -a "$SAGE_FRAMEWORK" "$target/sage" &
    spin $! "Copying framework..."
    echo -e "  ${GREEN}✓${RESET} sage/ copied to project"
  fi
}

select_preset() {
  local target="$1"
  SELECTED_PRESET=""

  # Check for --preset flag (set by CLI parser)
  if [ -n "${PRESET_FLAG:-}" ]; then
    case "$PRESET_FLAG" in
      base|startup|enterprise|opensource|none)
        SELECTED_PRESET="$PRESET_FLAG"
        echo -e "  ${GREEN}Preset:${RESET} $SELECTED_PRESET"
        return
        ;;
      *)
        echo -e "  ${YELLOW}Unknown preset: $PRESET_FLAG. Using base.${RESET}"
        SELECTED_PRESET="base"
        return
        ;;
    esac
  fi

  # Check if constitution already exists (re-init)
  if [ -f "$target/.sage/constitution.md" ]; then
    local existing
    existing=$(sed -n '/^extends:/s/^extends: *//p' "$target/.sage/constitution.md" 2>/dev/null)
    if [ -n "$existing" ]; then
      SELECTED_PRESET="$existing"
      echo -e "  ${GREEN}Preset:${RESET} $existing (from existing constitution)"
      return
    fi
  fi

  # Ask interactively
  if [ -t 0 ]; then
    local choice
    choice=$(ask_choice "Select a constitution preset:" \
      "base — universal engineering principles (default)" \
      "startup — ship fast, monolith first, one way to do things" \
      "enterprise — auth everywhere, audit trails, postmortems" \
      "opensource — docs mirror code, semver contract, contributor-friendly" \
      "none — base only, no preset")
    case "$choice" in
      2) SELECTED_PRESET="startup" ;;
      3) SELECTED_PRESET="enterprise" ;;
      4) SELECTED_PRESET="opensource" ;;
      5) SELECTED_PRESET="base" ;;
      *) SELECTED_PRESET="base" ;;
    esac
  else
    SELECTED_PRESET="base"
  fi
  echo -e "  ${GREEN}Preset:${RESET} $SELECTED_PRESET"
}

apply_prefix_config() {
  local config="$1/.sage/config.yaml"
  [ -f "$config" ] || return 0
  local prefix_val="false"
  [ "$PREFIX_FLAG" = "true" ] && prefix_val="true"
  if grep -q 'command_prefix:' "$config" 2>/dev/null; then
    sed -i "s/^command_prefix:.*$/command_prefix: $prefix_val/" "$config"
  else
    echo "command_prefix: $prefix_val" >> "$config"
  fi
}

create_sage_state() {
  local target="$1"
  local project_name
  project_name=$(basename "$target")

  if [ -d "$target/.sage" ]; then
    # Still apply prefix flag to existing config
    [ "$PREFIX_FLAG" = "true" ] && apply_prefix_config "$target"
    echo -e "  ${GREEN}✓${RESET} .sage/ preserved (existing state)"
    return
  fi

  local sage_dir="$target/.sage"
  mkdir -p "$sage_dir/work" "$sage_dir/docs" "$sage_dir/gates/scripts"

  local prefix_val="false"
  [ "$PREFIX_FLAG" = "true" ] && prefix_val="true"

  cat > "$sage_dir/config.yaml" << YAML
sage-version: "1.0.0"
project-name: "$project_name"
detected-stack: [$DETECTED_STACK]
auto_review: true
auto_qa: true
independent_gate3: true
command_prefix: $prefix_val
YAML

  cat > "$sage_dir/decisions.md" << MD
# Decisions

Shared log for significant decisions and context.
Both the AI agent and human collaborators write here.

- [$(date +%Y-%m-%d)] Sage initialized for $project_name
MD

  cat > "$sage_dir/conventions.md" << MD
# Project Conventions

Discovered by Sage on $(date +%Y-%m-%d).
The codebase-scan capability will enrich this on first run.
MD

  # Gate scripts
  for script in "$SAGE_FRAMEWORK/core/gates/scripts/"*.sh; do
    [ -f "$script" ] || continue
    cp "$script" "$sage_dir/gates/scripts/"
    chmod +x "$sage_dir/gates/scripts/$(basename "$script")"
  done

  # Gate activation config
  local gate_config="$SAGE_FRAMEWORK/core/gates/_config/gate-modes.yaml"
  if [ -f "$gate_config" ]; then
    cp "$gate_config" "$sage_dir/gates/gate-modes.yaml"
  fi

  # Constitution
  if [ -n "${SELECTED_PRESET:-}" ] && [ "$SELECTED_PRESET" != "base" ] && [ "$SELECTED_PRESET" != "none" ]; then
    cat > "$sage_dir/constitution.md" << CONSTMD
---
name: "$project_name"
extends: $SELECTED_PRESET
---

## Project Additions

(Add project-specific principles here)
CONSTMD
  fi

  echo -e "  ${GREEN}✓${RESET} .sage/ initialized"
}

run_generators() {
  local target="$1"
  local sage_path="$target/sage"
  [ -d "$sage_path" ] || sage_path="$SAGE_FRAMEWORK"

  if [ "$PLATFORM" = "antigravity" ] || [ "$PLATFORM" = "both" ]; then
    echo ""
    bash "$sage_path/runtime/platforms/antigravity/setup/generate-antigravity.sh" "$target"
  fi

  if [ "$PLATFORM" = "claude-code" ] || [ "$PLATFORM" = "both" ]; then
    echo ""
    bash "$sage_path/runtime/platforms/claude-code/setup/generate-claude-code.sh" "$target"
  fi
}

print_success() {
  local target="$1"
  local project_name
  project_name=$(basename "$target")

  # Constitution info
  local preset_info="base"
  [ -n "${SELECTED_PRESET:-}" ] && [ "$SELECTED_PRESET" != "base" ] && preset_info="$SELECTED_PRESET"

  sage_complete

  # Command prefix display
  local p=""
  [ "$PREFIX_FLAG" = "true" ] && p="sage:"

  echo -e "  ${BOLD}Get started:${RESET}"
  echo ""
  if [ "$PLATFORM" = "claude-code" ] || [ "$PLATFORM" = "both" ]; then
    echo "    1. Open this project in your IDE"
    echo -e "    2. Type ${BOLD}/sage${RESET} and describe what you want to build"
    echo ""
    echo -e "  ${DIM}Commands: /${p}build  /${p}fix  /${p}architect  /${p}status  /${p}review  /${p}learn${RESET}"
  fi
  if [ "$PLATFORM" = "antigravity" ] && [ "$PLATFORM" != "both" ]; then
    echo "    1. Open this project in Antigravity"
    echo -e "    2. Type ${BOLD}/sage${RESET} and describe what you want to build"
    echo ""
    echo -e "  ${DIM}Commands: /${p}build  /${p}fix  /${p}architect  /${p}status  /${p}review  /${p}learn${RESET}"
  fi

  # Check for sage-memory
  local has_memory=false
  if [ -f "$HOME/.claude.json" ] && grep -q "sage-memory" "$HOME/.claude.json" 2>/dev/null; then
    has_memory=true
  fi
  if [ -f "$target/.claude.json" ] && grep -q "sage-memory" "$target/.claude.json" 2>/dev/null; then
    has_memory=true
  fi

  if [ "$has_memory" = false ]; then
    echo ""
    echo -e "  ${DIM}Enable persistent memory:  sage setup memory${RESET}"
  fi

  echo ""
}

# ═══════════════════════════════════════════════════════════════
# COMMAND: new <name>
# ═══════════════════════════════════════════════════════════════
sage_new() {
  local name="${1:-}"

  echo ""
  echo -e "  ${BOLD}Sage — New Project${RESET}"
  echo ""

  if [ -z "$name" ]; then
    printf "  Project name: " >&2
    read -r name
    if [ -z "$name" ]; then
      echo -e "  ${RED}❌ Project name is required.${RESET}"
      exit 1
    fi
  fi

  if [[ "$name" =~ [\ /\\] ]]; then
    echo -e "  ${RED}❌ Project name cannot contain spaces or slashes.${RESET}"
    exit 1
  fi

  if [ -d "$name" ]; then
    echo -e "  ${RED}❌ Directory '$name' already exists.${RESET}"
    echo "  Use 'sage init' inside it instead."
    exit 1
  fi

  echo -e "  Creating ${CYAN}$name${RESET}..."
  timer_start
  step_start

  mkdir -p "$name"
  local target
  target="$(cd "$name" && pwd)"

  copy_framework "$target"

  # Git init
  if [ ! -d "$target/.git" ]; then
    (cd "$target" && git init -q 2>/dev/null) || true
    echo -e "  ${GREEN}✓${RESET} Git initialized"
  fi

  detect_stack "$target"
  select_platform "$target"
  select_preset "$target"
  create_sage_state "$target"
  run_generators "$target"
  print_success "$target"
}

# ═══════════════════════════════════════════════════════════════
# COMMAND: init
# ═══════════════════════════════════════════════════════════════
sage_init() {
  local target
  target="$(pwd)"

  # Safety: don't init inside sage/ framework itself
  if [ -f "$target/core/registry.yaml" ] && [ -d "$target/core/capabilities" ]; then
    echo ""
    echo -e "  ${RED}❌ You're inside the Sage framework directory.${RESET}"
    echo ""
    echo "  Run from your project directory instead:"
    echo "    cd /path/to/your/project"
    echo "    sage init"
    exit 1
  fi

  echo ""
  echo -e "  ${BOLD}Sage — Initialize Project${RESET}"
  echo ""
  echo -e "  Project: ${CYAN}$(basename "$target")${RESET}"
  echo -e "  Path:    ${DIM}$target${RESET}"
  timer_start
  step_start

  # Check if already initialized
  if [ -d "$target/.sage" ] && [ -d "$target/sage" ]; then
    echo -e "  ${YELLOW}Sage is already initialized in this project.${RESET}"
    echo ""
    echo "  To regenerate platform files: sage update"
    echo "  To start over: remove .sage/ and sage/ first"
    echo ""
    printf "  Reinstall anyway? [y/N]: "
    read -r confirm
    if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
      echo "  Cancelled."
      exit 0
    fi
    echo ""
  fi

  copy_framework "$target"
  detect_stack "$target"
  select_platform "$target"
  select_preset "$target"
  create_sage_state "$target"
  run_generators "$target"
  print_success "$target"
}

# ═══════════════════════════════════════════════════════════════
# COMMAND: update
# ═══════════════════════════════════════════════════════════════
sage_update() {
  local target
  target="$(pwd)"

  if [ ! -d "$target/.sage" ]; then
    echo ""
    echo -e "  ${RED}❌ No Sage project found here.${RESET}"
    echo "  Run this from a directory with .sage/"
    echo "  Or run 'sage init' to set up Sage first."
    exit 1
  fi

  echo ""
  echo -e "  ${BOLD}Sage — Update Project${RESET}"
  echo ""
  echo -e "  Project: ${CYAN}$(basename "$target")${RESET}"
  timer_start
  step_start

  # Detect platform
  PLATFORM=""
  [ -f "$target/GEMINI.md" ] || [ -d "$target/.agent" ] && PLATFORM="antigravity"
  if [ -f "$target/CLAUDE.md" ] && head -1 "$target/CLAUDE.md" 2>/dev/null | grep -q "Sage"; then
    [ -z "$PLATFORM" ] && PLATFORM="claude-code" || PLATFORM="both"
  fi
  if [ -d "$target/.claude/commands" ]; then
    [ -z "$PLATFORM" ] && PLATFORM="claude-code" || [ "$PLATFORM" = "antigravity" ] && PLATFORM="both"
  fi

  if [ -z "$PLATFORM" ]; then
    echo -e "  ${YELLOW}No platform files found.${RESET}"
    echo "  Selecting platform..."
    select_platform "$target"
  else
    echo -e "  ${GREEN}Platform:${RESET} $PLATFORM"
  fi

  # Detect community skills before updating
  local community_skills=""
  if [ -f "$target/sage/skills/skills.json" ]; then
    community_skills=$(python3 -c "
import json, sys
try:
  d = json.load(open('$target/sage/skills/skills.json'))
  cs = [k for k, v in d.get('skills', {}).items() if v.get('source') != 'built-in']
  print(' '.join(cs))
except: pass
" 2>/dev/null)
  fi

  # Show what will happen
  echo ""
  echo "  This will:"
  if [ -d "$target/sage" ]; then
    echo -e "    ${CYAN}↻${RESET} Update sage/ framework to latest version"
  fi
  if [ "$PLATFORM" = "antigravity" ] || [ "$PLATFORM" = "both" ]; then
    echo -e "    ${CYAN}↻${RESET} Regenerate GEMINI.md and .agent/"
  fi
  if [ "$PLATFORM" = "claude-code" ] || [ "$PLATFORM" = "both" ]; then
    echo -e "    ${CYAN}↻${RESET} Regenerate CLAUDE.md and .claude/commands/"
  fi
  echo -e "    ${GREEN}✓${RESET} Preserve .sage/ project state (untouched)"
  if [ -n "$community_skills" ]; then
    echo -e "    ${GREEN}✓${RESET} Preserve community skills: $community_skills"
  fi

  echo ""
  if [ -t 0 ]; then
    printf "  [A] Proceed  |  [C] Cancel: "
    read -r confirm
    if [ "$confirm" != "A" ] && [ "$confirm" != "a" ] && [ "$confirm" != "" ]; then
      echo "  Cancelled."
      echo ""
      return
    fi
  fi

  echo ""

  # Backup community skills
  local backup_dir=""
  if [ -n "$community_skills" ]; then
    backup_dir=$(mktemp -d)
    for skill_name in $community_skills; do
      if [ -d "$target/sage/skills/$skill_name" ]; then
        cp -a "$target/sage/skills/$skill_name" "$backup_dir/"
      fi
    done
  fi

  # Update sage/ framework
  if [ -d "$target/sage" ]; then
    rm -rf "$target/sage"
    cp -a "$SAGE_FRAMEWORK" "$target/sage" &
    spin $! "Updating framework..."
    echo -e "  ${GREEN}✓${RESET} sage/ updated"
  fi

  # Restore community skills
  if [ -n "$community_skills" ] && [ -n "$backup_dir" ]; then
    for skill_name in $community_skills; do
      if [ -d "$backup_dir/$skill_name" ]; then
        cp -a "$backup_dir/$skill_name" "$target/sage/skills/"
      fi
    done
    rm -rf "$backup_dir"

    # Re-register community skills in skills.json
    python3 -c "
import json, sys
try:
  with open('$target/sage/skills/skills.json') as f:
    d = json.load(f)
  for s in '$community_skills'.split():
    if s not in d.get('skills', {}):
      d.setdefault('skills', {})[s] = {'source': 'community', 'added': '$(date +%Y-%m-%d)'}
  with open('$target/sage/skills/skills.json', 'w') as f:
    json.dump(d, f, indent=2)
except: pass
" 2>/dev/null

    echo -e "  ${GREEN}✓${RESET} Community skills preserved: $community_skills"
  fi

  # Apply --prefix flag if provided
  [ "$PREFIX_FLAG" = "true" ] && apply_prefix_config "$target"

  # Regenerate platform files
  DETECTED_STACK=""
  detect_stack "$target"
  export SAGE_UPDATE_MODE=true
  run_generators "$target"
  unset SAGE_UPDATE_MODE

  # ── Migration: clean stale patterns from previous versions ──
  local migrated=0
  local migration_notes=""

  # Remove tasks-total/tasks-done from plan frontmatter
  for plan in "$target"/.sage/work/*/plan.md; do
    [ -f "$plan" ] || continue
    if grep -q "tasks-total\|tasks-done" "$plan" 2>/dev/null; then
      sed -i.bak '/^tasks-total:/d; /^tasks-done:/d' "$plan"
      rm -f "${plan}.bak"
      migrated=$((migrated + 1))
    fi
  done
  [ "$migrated" -gt 0 ] && migration_notes="${migration_notes}\n  ${CYAN}↻${RESET} Migrated $migrated plan file(s) (removed stale task count fields)"

  # Migrate journal.md → decisions.md
  if [ -f "$target/.sage/journal.md" ] && [ ! -f "$target/.sage/decisions.md" ]; then
    # Strip artifact index table, keep change log entries
    sed -n '/^## Change Log/,$ p' "$target/.sage/journal.md" | sed '1d' > /tmp/sage-journal-entries.tmp 2>/dev/null
    cat > "$target/.sage/decisions.md" << DECMD
# Decisions

Shared log for significant decisions and context.
Both the AI agent and human collaborators write here.

$(cat /tmp/sage-journal-entries.tmp 2>/dev/null)
DECMD
    rm -f /tmp/sage-journal-entries.tmp
    migration_notes="${migration_notes}\n  ${CYAN}↻${RESET} Migrated journal.md → decisions.md (artifact table removed, change log preserved)"
  fi

  # Create decisions.md if neither journal nor decisions exist
  if [ ! -f "$target/.sage/decisions.md" ]; then
    cat > "$target/.sage/decisions.md" << DECMD
# Decisions

Shared log for significant decisions and context.
Both the AI agent and human collaborators write here.

- [$(date +%Y-%m-%d)] Sage updated to v1.0.7
DECMD
    migration_notes="${migration_notes}\n  ${GREEN}✓${RESET} decisions.md created"
  fi

  if [ -n "$migration_notes" ]; then
    echo ""
    echo -e "$migration_notes"
  fi

  echo ""
  echo -e "  ${GREEN}✓${RESET} Platform files regenerated"
  echo -e "  ${GREEN}✓${RESET} .sage/ state preserved"

  sage_complete
}

# ═══════════════════════════════════════════════════════════════
# COMMAND: upgrade
# ═══════════════════════════════════════════════════════════════
sage_upgrade() {
  local sage_home="${SAGE_HOME:-$HOME/.sage}"

  echo ""
  echo -e "  ${BOLD}Sage — Upgrade Framework${RESET}"
  echo ""

  if [ ! -d "$sage_home/framework" ]; then
    echo -e "  ${RED}❌ Sage not installed globally.${RESET}"
    echo "  Install first:"
    echo "    curl -fsSL https://raw.githubusercontent.com/xoai/sage/main/install.sh | bash"
    exit 1
  fi

  if [ -d "$sage_home/framework/.git" ]; then
    timer_start
    step_start
    (cd "$sage_home/framework" && git pull --ff-only 2>/dev/null) &
    if spin $! "Pulling latest from GitHub..."; then
      echo -e "  ${GREEN}✓${RESET} Sage upgraded to latest"
      echo ""
      echo "  Run 'sage update' in your projects to regenerate platform files."
    else
      echo ""
      echo -e "  ${YELLOW}Could not pull updates.${RESET}"
      echo "  Try reinstalling:"
      echo "    curl -fsSL https://raw.githubusercontent.com/xoai/sage/main/install.sh | bash"
    fi
  else
    echo "  Sage was installed from a local copy (no git remote)."
    echo ""
    echo "  To upgrade, re-run the installer with the latest source:"
    echo "    curl -fsSL https://raw.githubusercontent.com/xoai/sage/main/install.sh | bash"
    echo ""
    echo "  Or download the latest release and run:"
    echo "    bash install.sh"
  fi
  echo ""
}

# ═══════════════════════════════════════════════════════════════
# SKILL MANAGEMENT (delegates to Python)
# ═══════════════════════════════════════════════════════════════

require_python() {
  if ! command -v python3 &>/dev/null; then
    echo ""
    echo -e "  ${RED}Skill management requires Python 3.8+${RESET}"
    echo "  Install Python: https://www.python.org/downloads/"
    exit 1
  fi
}

skill_manager() {
  require_python
  local manager="$SAGE_FRAMEWORK/runtime/tools/skill_manager.py"
  if [ ! -f "$manager" ]; then
    echo -e "  ${RED}❌ skill_manager.py not found at $manager${RESET}"
    exit 1
  fi
  python3 "$manager" "$@"
}

sage_find() {
  skill_manager find "$@"
}

sage_add() {
  skill_manager add "$@"
}

sage_remove() {
  skill_manager remove "$@"
}

sage_skills() {
  skill_manager list "$@"
}

# ═══════════════════════════════════════════════════════════════
# COMMAND: setup
# ═══════════════════════════════════════════════════════════════
sage_setup() {
  local component="${1:-}"

  if [ "$component" != "memory" ]; then
    echo ""
    echo -e "  ${BOLD}Sage — Setup${RESET}"
    echo ""
    echo "  Usage: sage setup memory"
    echo ""
    return
  fi

  echo ""
  echo -e "  ${BOLD}Sage — Setup Memory${RESET}"
  echo ""
  echo "  sage-memory gives your AI agent persistent knowledge across sessions."
  echo "  It remembers architecture decisions, conventions, debugging insights,"
  echo "  and project patterns — so the agent never starts from scratch."
  echo ""
  echo -e "  ${BOLD}Step 1:${RESET} Add to your MCP config"
  echo ""

  # Detect platform
  if [ -d ".claude" ] || [ -f "$HOME/.claude.json" ]; then
    echo -e "  ${CYAN}Claude Code${RESET} — add to ~/.claude.json:"
    echo ""
    echo '  {'
    echo '    "mcpServers": {'
    echo '      "sage-memory": {'
    echo '        "command": "uvx",'
    echo '        "args": ["sage-memory"]'
    echo '      }'
    echo '    }'
    echo '  }'
  elif [ -d ".cursor" ]; then
    echo -e "  ${CYAN}Cursor${RESET} — add to .cursor/mcp.json:"
    echo ""
    echo '  {'
    echo '    "mcpServers": {'
    echo '      "sage-memory": {'
    echo '        "command": "uvx",'
    echo '        "args": ["sage-memory"]'
    echo '      }'
    echo '    }'
    echo '  }'
  else
    echo "  Add to your MCP client config:"
    echo ""
    echo '  {'
    echo '    "mcpServers": {'
    echo '      "sage-memory": {'
    echo '        "command": "uvx",'
    echo '        "args": ["sage-memory"]'
    echo '      }'
    echo '    }'
    echo '  }'
  fi

  echo ""
  echo -e "  ${BOLD}Step 2:${RESET} Restart your IDE"
  echo ""
  echo "  That's it. Sage will automatically search and store knowledge"
  echo "  as you work. No configuration needed."
  echo ""
  echo -e "  ${DIM}Requires uv: curl -LsSf https://astral.sh/uv/install.sh | sh${RESET}"
  echo -e "  ${DIM}More info: https://github.com/xoai/sage-memory${RESET}"
  echo ""
}

# ═══════════════════════════════════════════════════════════════
# COMMAND: learn
# ═══════════════════════════════════════════════════════════════
sage_learn() {
  local target="${1:-.}"

  echo ""
  echo -e "  ${BOLD}Sage — Learn${RESET}"
  echo ""

  # Check if we're in a Sage project
  if [ ! -d "sage/skills" ] && [ ! -d ".sage" ]; then
    echo -e "  ${RED}❌ No Sage project found here.${RESET}"
    echo "  Run this from a Sage project directory."
    exit 1
  fi

  if [ "$target" = "." ]; then
    echo -e "  ${CYAN}Broad scan:${RESET} learning the whole project"
  else
    if [ ! -e "$target" ]; then
      echo -e "  ${RED}❌ Target not found: $target${RESET}"
      exit 1
    fi
    echo -e "  ${CYAN}Deep dive:${RESET} $target"
  fi

  echo ""
  echo "  This command works inside your AI agent (Claude Code, Antigravity)."
  echo "  Open this project in your IDE, then tell the agent:"
  echo ""

  if [ "$target" = "." ]; then
    echo -e "    ${BOLD}\"Learn this project. Do a broad scan and store${RESET}"
    echo -e "    ${BOLD} what you learn in memory.\"${RESET}"
  else
    echo -e "    ${BOLD}\"Learn $target. Do a deep dive and store${RESET}"
    echo -e "    ${BOLD} what you learn in memory.\"${RESET}"
  fi

  echo ""
  echo "  The agent will follow the memory skill\'s learn workflow:"
  echo "    1. Scan structure and key files"
  echo "    2. Identify patterns, conventions, architecture"
  echo "    3. Store focused memories in sage-memory"
  echo "    4. Generate knowledge report → .sage/docs/memory-{name}.md"
  echo ""
  echo -e "  ${DIM}Requires sage-memory MCP server. Setup: https://github.com/xoai/sage-memory${RESET}"
  echo ""
}

# ═══════════════════════════════════════════════════════════════
# COMMAND: help
# ═══════════════════════════════════════════════════════════════
sage_help() {
  echo ""
  echo -e "${BOLD}Sage${RESET} — An intelligent skills framework for AI agents"
  echo ""
  echo "Project commands:"
  echo "  sage new <n>                  Create a new project with Sage"
  echo "  sage init [--prefix]             Add Sage to the current directory"
  echo "  sage update                      Regenerate platform files"
  echo "  sage upgrade                     Update Sage to the latest version"
  echo "  sage learn [path]                Learn a codebase or module"
  echo "  sage setup memory                Configure persistent memory"
  echo ""
  echo "Skill management (powered by skills.sh):"
  echo "  sage find <query>                Search skills.sh catalog"
  echo "  sage add <source>                Install skills from owner/repo, URL, or path"
  echo "  sage add <source> --skill <n>    Install a specific skill from a repo"
  echo "  sage add <source> --all          Install all skills from a repo"
  echo "  sage remove <skill>              Remove a skill from project"
  echo "  sage skills                      List installed skills"
  echo "  sage update [target]             Update community skills"
  echo ""
  echo "  sage help                        Show this help"
  echo ""
  echo "Flags:"
  echo "  --prefix                         Namespace commands as sage:build, sage:fix, etc."
  echo "  --preset <name>                  Set constitution preset (base|startup|enterprise|opensource)"
  echo ""
  echo "Examples:"
  echo "  sage new my-app                  # Create project with Sage"
  echo "  sage init --prefix               # Add Sage with sage: prefixed commands"
  echo "  sage learn                       # Broad scan of whole project"
  echo "  sage learn src/billing/          # Deep dive into a module"
  echo "  sage find react                  # Search skills.sh for React skills"
  echo "  sage add vercel-labs/agent-skills               # Browse + pick skills"
  echo "  sage add vercel-labs/agent-skills --skill react  # Install specific skill"
  echo "  sage add ./my-local-skills                      # Install from local path"
  echo ""
}

# ═══════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════
COMMAND="${1:-}"
shift 2>/dev/null || true

# Parse flags from remaining args
PRESET_FLAG=""
PREFIX_FLAG=""
REMAINING_ARGS=()
for arg in "$@"; do
  case "$arg" in
    --preset=*) PRESET_FLAG="${arg#--preset=}" ;;
    --preset)   PRESET_FLAG="__NEXT__" ;;
    --prefix)   PREFIX_FLAG="true" ;;
    *)
      if [ "$PRESET_FLAG" = "__NEXT__" ]; then
        PRESET_FLAG="$arg"
      else
        REMAINING_ARGS+=("$arg")
      fi
      ;;
  esac
done
set -- ${REMAINING_ARGS[@]+"${REMAINING_ARGS[@]}"}

case "$COMMAND" in
  new)              sage_new "$@" ;;
  init)             sage_init ;;
  update)           sage_update ;;
  upgrade)          sage_upgrade ;;
  learn)            sage_learn "$@" ;;
  setup)            sage_setup "$@" ;;
  find)             sage_find "$@" ;;
  add)              sage_add "$@" ;;
  remove)           sage_remove "$@" ;;
  skills)           sage_skills "$@" ;;
  help|--help|-h)   sage_help ;;
  "")               sage_help ;;
  *)
    echo -e "${RED}Unknown command: $COMMAND${RESET}"
    sage_help
    exit 1
    ;;
esac
