# .sage/agents.toml
# Source of truth for which CLI agent + model handles each role.
# Change `agent` / `model` / `mode` under a role to swap tools.
# Slash commands and scripts read this; they don't hardcode tool names.
#
# Generated by `sage setup multi-agent` v{{SAGE_VERSION}} on {{DATE}}.
# This file is yours — `sage update` will not overwrite it.

# ─────────────────────────────────────────────────────────────────────
# Roles
# ─────────────────────────────────────────────────────────────────────

[roles.planner]
# Writes brief.md, spec.md, plan.md, architecture decisions.
# Runs inside the main Claude Code session — no external invocation.
agent = "claude"
model = "claude-opus-4-7"
mode  = "interactive"

[roles.implementer]
# Edits source code, runs tests, writes implementer-notes.md.
# Must be a CLI that can modify the workspace.
agent = "kimi"
model = "kimi-for-coding"
mode  = "yolo"          # --print implies --yolo

[roles.spec_reviewer]
# Adversarial review of spec.md / plan.md. Read-only.
agent = "codex"
# Empty → run-role.sh omits --model and codex uses its own configured
# default. Pin a model here only if your codex auth supports it (an
# API-key account); a ChatGPT-account codex rejects some model names.
model = ""
mode  = "read-only"

[roles.code_reviewer]
# Adversarial review of the uncommitted diff against spec + plan. Read-only.
agent = "codex"
# See [roles.spec_reviewer] above — empty model = codex's own default.
model = ""
mode  = "read-only"

# ─────────────────────────────────────────────────────────────────────
# Agents — how each CLI is invoked.
# Roles reference these by the key after `agents.`.
#
# Fields:
#   kind            "host" (Claude itself) | "cli"
#   command         binary name on PATH
#   exec_subcommand subcommand inserted as first arg (e.g. codex's "exec")
#   prompt_style    "argv"  — prompt is the last positional arg
#                   "flag"  — prompt is passed via --prompt
#                   "stdin" — prompt is piped to stdin
#   flags           always-applied flags
#   modes.<name>    extra flags appended when role.mode == <name>
#   model_flag      flag used to pass model name (empty = skip)
#   output_flag     flag used to redirect final message to a file
#                   (empty = redirect stdout instead)
# ─────────────────────────────────────────────────────────────────────

[agents.claude]
kind = "host"
# No invocation block — the planner role runs in-session as the orchestrator.

[agents.codex]
kind            = "cli"
command         = "codex"
exec_subcommand = "exec"
prompt_style    = "argv"
flags           = ["--skip-git-repo-check"]
model_flag      = "--model"
output_flag     = "--output-last-message"

[agents.codex.modes]
read-only = ["--sandbox", "read-only"]
workspace = ["--sandbox", "workspace-write"]
yolo      = ["--full-auto"]

[agents.kimi]
kind         = "cli"
command      = "kimi"
prompt_style = "flag"          # kimi uses --prompt "..."
flags        = ["--print", "--quiet"]
model_flag   = "--model"
output_flag  = ""              # kimi prints to stdout; we redirect

[agents.kimi.modes]
plan      = ["--plan"]
yolo      = ["--yolo"]
read-only = ["--plan"]         # kimi has no separate review mode

# ─────────────────────────────────────────────────────────────────────
# Example: adding a hypothetical Gemini CLI as a reviewer alternative.
# Uncomment, point [roles.code_reviewer] at it, done.
